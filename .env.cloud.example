# Cloud deployment (API + Streamlit UI only — full streaming stack needs Docker/VPS)
# Copy into Render/Railway environment settings.

PYTHONPATH=.
APP_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/analytics_pipeline
REDIS_HOST=your-redis-host
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=your-kafka-host:9092

# Streamlit Cloud secret
API_BASE_URL=https://your-api-url.onrender.com
